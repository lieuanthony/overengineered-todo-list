# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# -----------------------------------------------
# Dependencies
# -----------------------------------------------
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------
# Testing
# -----------------------------------------------
/coverage
*.lcov
.nyc_output

# -----------------------------------------------
# Next.js
# -----------------------------------------------
/.next/
/out/
frontend/.next/
frontend/out/

# -----------------------------------------------
# Build outputs
# -----------------------------------------------
/build
/dist
backend/dist/
frontend/.next/

# -----------------------------------------------
# Environment files
# -----------------------------------------------
.env
.env.local
.env.development
.env.production
.env.*.local
# Keep .env.example committed as a template

# -----------------------------------------------
# Terraform
# -----------------------------------------------
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfstate.lock.info
terraform/terraform.tfvars
*.tfplan

# -----------------------------------------------
# Docker
# -----------------------------------------------
.docker/

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# -----------------------------------------------
# TypeScript
# -----------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------
# Certificates & keys
# -----------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx

# -----------------------------------------------
# OS
# -----------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------
# IDE
# -----------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# -----------------------------------------------
# Misc
# -----------------------------------------------
.vercel
.cache/
tmp/
temp/